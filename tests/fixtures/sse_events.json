{
  "description": "Shared SSE event contract for Agent Host, BFF, and frontend consumer.",
  "version": 2,
  "required_event_types": [
    "trace",
    "session",
    "token",
    "tool_start",
    "tool_end",
    "file_ready",
    "approval_required",
    "interaction_requested",
    "interaction_resolved",
    "task_plan_updated",
    "context_stats",
    "context_warning",
    "compaction_started",
    "compaction_completed",
    "compaction_failed",
    "extension_loaded",
    "extension_error",
    "extension_notification",
    "extension_status",
    "tool_policy_decision",
    "mcp_discovered",
    "mcp_invoked",
    "mcp_failed",
    "structured_output",
    "error",
    "done",
    "session_closed"
  ],
  "event_shapes": {
    "trace": { "type": "trace", "trace_id": "string" },
    "session": {
      "type": "session",
      "session_id": "string",
      "workspace_id": "string?",
      "conversation_id": "string?",
      "session_reused": "boolean?",
      "trace_id": "string?"
    },
    "token": { "type": "token", "text": "string" },
    "tool_start": { "type": "tool_start", "id": "string", "name": "string", "args": "object?" },
    "tool_end": {
      "type": "tool_end",
      "id": "string",
      "name": "string",
      "result": "any",
      "isError": "boolean?"
    },
    "file_ready": {
      "type": "file_ready",
      "artifact_id": "string?",
      "path": "string?",
      "name": "string?",
      "mime_type": "string?",
      "size": "number?"
    },
    "approval_required": {
      "type": "approval_required",
      "approval_id": "string",
      "tool_name": "string?",
      "command": "string?",
      "path": "string?",
      "reason": "string?",
      "risk_level": "string?"
    },
    "interaction_requested": { "type": "interaction_requested", "interaction_id": "string", "interaction_type": "string" },
    "interaction_resolved": { "type": "interaction_resolved", "interaction_id": "string" },
    "task_plan_updated": { "type": "task_plan_updated", "tasks": "array" },
    "context_stats": { "type": "context_stats", "tokens": "number?", "context_window": "number?" },
    "context_warning": { "type": "context_warning", "percent": "number?" },
    "compaction_started": { "type": "compaction_started", "reason": "string?" },
    "compaction_completed": { "type": "compaction_completed", "reason": "string?" },
    "compaction_failed": { "type": "compaction_failed", "reason": "string?", "error": "string" },
    "extension_loaded": { "type": "extension_loaded", "extension": "string?" },
    "extension_error": { "type": "extension_error", "error": "string" },
    "extension_notification": { "type": "extension_notification", "message": "string" },
    "extension_status": { "type": "extension_status", "key": "string", "text": "string?" },
    "tool_policy_decision": { "type": "tool_policy_decision", "decision": "string?" },
    "mcp_discovered": { "type": "mcp_discovered", "count": "number" },
    "mcp_invoked": { "type": "mcp_invoked", "tool": "string", "result_ref": "string?" },
    "mcp_failed": { "type": "mcp_failed", "tool": "string?", "error": "string" },
    "structured_output": { "type": "structured_output", "valid": "boolean", "value": "any" },
    "error": { "type": "error", "message": "string" },
    "done": { "type": "done" },
    "session_closed": { "type": "session_closed", "session_id": "string?" }
  },
  "sample_stream": [
    { "type": "trace", "trace_id": "trace_example" },
    {
      "type": "session",
      "session_id": "sandbox_abc",
      "workspace_id": "conv_xyz",
      "conversation_id": "conv_xyz",
      "session_reused": false,
      "trace_id": "trace_example"
    },
    { "type": "token", "text": "Working on it." },
    {
      "type": "tool_start",
      "id": "call_1",
      "name": "write",
      "args": { "path": "note.txt", "content": "hi" }
    },
    {
      "type": "tool_end",
      "id": "call_1",
      "name": "write",
      "result": "Written 2 bytes to note.txt",
      "isError": false
    },
    {
      "type": "tool_start",
      "id": "call_2",
      "name": "submit_artifact",
      "args": { "path": "note.txt" }
    },
    {
      "type": "tool_end",
      "id": "call_2",
      "name": "submit_artifact",
      "result": "{\"artifact_id\":\"art_1\",\"path\":\"note.txt\"}",
      "isError": false
    },
    {
      "type": "file_ready",
      "artifact_id": "art_1",
      "path": "note.txt",
      "name": "note.txt",
      "mime_type": "application/octet-stream",
      "size": 2
    },
    { "type": "done" },
    { "type": "session_closed", "session_id": "sandbox_abc" }
  ]
}
