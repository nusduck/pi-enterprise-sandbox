# ════════════════════════════════════════════════════════════════════
# Pi Enterprise Sandbox — Environment Configuration
# ════════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.example .env
#   vi .env
# ════════════════════════════════════════════════════════════════════

# ── LLM Provider (REQUIRED) ──────────────────────────────────────────
# llmio gateway or any OpenAI-compatible API
LLMIO_BASE_URL=https://your-llmio-gateway.example.com/openai/v1
LLMIO_API_KEY=sk-your-api-key-here

# Model to use
PI_MODEL=deepseek-v4-flash

# ── Auth (RECOMMENDED — single API token for all endpoints) ──────────
# Generate with: openssl rand -hex 32
# When set, all sandbox API calls require header: X-API-Key: <token>
# Health checks and metrics are exempt.
SANDBOX_API_TOKEN=

# ── Domain (for nginx SSL) ────────────────────────────────────────────
DOMAIN=localhost

# ── MCP Adapter ───────────────────────────────────────────────────────
SANDBOX_MCP_ENABLED=true
# Comma-separated list of allowed X-Auth-Token values for MCP
SANDBOX_MCP_AUTH_TOKENS=

# ── Sandbox Service ───────────────────────────────────────────────────
SANDBOX_LOG_LEVEL=INFO
SANDBOX_PORT=8081
SANDBOX_HOST_PORT=8083
SANDBOX_MCP_PORT=8091
SANDBOX_MCP_HOST_PORT=8093

# ── Database ───────────────────────────────────────────────────────────
# SQLite (default, single-instance):
SANDBOX_DATABASE_URL=sqlite:////sandbox/data/sandbox.db
# PostgreSQL (production, multi-instance):
# SANDBOX_DATABASE_URL=postgresql://sandbox:password@postgres:5432/sandbox

# ── Session & Cleanup ──────────────────────────────────────────────────
SANDBOX_SESSION_TTL_MINUTES=30
SANDBOX_CLEANUP_INTERVAL_MINUTES=5

# ── Execution Limits ───────────────────────────────────────────────────
SANDBOX_EXECUTION_TIMEOUT_SECONDS=120
SANDBOX_MAX_OUTPUT_CHARS=50000
SANDBOX_MAX_PROCESS_COUNT=20
SANDBOX_MAX_CPU_TIME_SECONDS=300
SANDBOX_MAX_MEMORY_MB=512
SANDBOX_MAX_FILE_SIZE_MB=50
SANDBOX_WORKSPACE_QUOTA_MB=500

# ── Network Isolation ──────────────────────────────────────────────────
SANDBOX_IPTABLES_ENABLED=true
SANDBOX_IPTABLES_DEFAULT_POLICY=DROP
# Comma-separated allowed ports/CIDRs (empty = only DNS + localhost)
SANDBOX_ALLOWED_TCP_PORTS=
SANDBOX_ALLOWED_UDP_PORTS=
SANDBOX_ALLOWED_CIDRS=

# ── Approval Workflow ──────────────────────────────────────────────────
SANDBOX_APPROVAL_TIMEOUT_SECONDS=300

# ── Uvicorn ────────────────────────────────────────────────────────────
SANDBOX_UVICORN_WORKERS=2
SANDBOX_UVICORN_PROXY_HEADERS=true

# ── Agent WebUI (host ports) ───────────────────────────────────────────
AGENT_PORT=3000
# No port needs to be exposed in production — nginx handles ingress

# ── Nginx ──────────────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── Container Resource Limits (deploy section) ────────────────────────
SANDBOX_CPU_LIMIT=2
SANDBOX_MEM_LIMIT=1g
AGENT_CPU_LIMIT=1
AGENT_MEM_LIMIT=512m
