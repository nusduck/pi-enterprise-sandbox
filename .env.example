# ════════════════════════════════════════════════════════════════════
# Pi Enterprise Sandbox — Environment Configuration (v4)
# ════════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.example .env && vi .env
# ════════════════════════════════════════════════════════════════════

# ── LLM Provider (REQUIRED) ──────────────────────────────────────────
# OpenAI-compatible API gateway (llmio, vLLM, OpenAI, etc.)
LLMIO_BASE_URL=https://your-llmio-gateway.example.com/openai/v1
LLMIO_API_KEY=sk-…
# Optional model id passed to the LLM gateway
MODEL_ID=deepseek-v4-flash

# ── Agent runtime cutover (api-server) ────────────────────────────────
# Who orchestrates POST /api/chat:
#   node   (default) — Node pi-coding-agent path (known-working)
#   python           — BFF proxies SSE to sandbox POST /agent/chat
# Rollback: set AGENT_RUNTIME=node and restart api-server (no frontend redeploy).
# Do not flip default to python until multi-turn/tool/approval/artifact/abort parity is verified.
AGENT_RUNTIME=node

# ── Auth (RECOMMENDED) ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# When set, sandbox API calls require header: X-API-Key: ***
# Public routes always exempt: /health, /ready, /metrics, /docs, /openapi, /redoc
SANDBOX_API_TOKEN=

# Optional JWT user auth foundation (off by default; multi-user ownership is separate work).
# When true, non-public routes accept Bearer JWT after register/login; service token remains X-API-Key.
# SANDBOX_AUTH_ENABLED=false
# SANDBOX_JWT_SECRET=
# SANDBOX_JWT_TTL_SECONDS=86400

# ── MCP Adapter ──────────────────────────────────────────────────────
SANDBOX_MCP_ENABLED=true
SANDBOX_MCP_AUTH_TOKENS=

# ── Sandbox Service ──────────────────────────────────────────────────
SANDBOX_LOG_LEVEL=INFO
SANDBOX_MCP_PORT=8091
SANDBOX_MCP_HOST_PORT=8093

# ── Database ─────────────────────────────────────────────────────────
# SQLite (default):
SANDBOX_DATABASE_URL=sqlite:////sandbox/data/sandbox.db

# ── Session & Cleanup ────────────────────────────────────────────────
SANDBOX_SESSION_TTL_MINUTES=30
SANDBOX_CLEANUP_INTERVAL_MINUTES=5

# ── Execution Limits ─────────────────────────────────────────────────
SANDBOX_EXECUTION_TIMEOUT_SECONDS=120
SANDBOX_MAX_OUTPUT_CHARS=50000
SANDBOX_MAX_PROCESS_COUNT=20
SANDBOX_MAX_CPU_TIME_SECONDS=300
SANDBOX_MAX_MEMORY_MB=512
SANDBOX_MAX_FILE_SIZE_MB=50
SANDBOX_WORKSPACE_QUOTA_MB=500

# ── Network Isolation ────────────────────────────────────────────────
SANDBOX_IPTABLES_ENABLED=true
SANDBOX_IPTABLES_DEFAULT_POLICY=DROP
SANDBOX_ALLOWED_TCP_PORTS=
SANDBOX_ALLOWED_UDP_PORTS=
SANDBOX_ALLOWED_CIDRS=

# ── Uvicorn ──────────────────────────────────────────────────────────
SANDBOX_UVICORN_WORKERS=2
