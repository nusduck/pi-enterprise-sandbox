# ── Pi Agent (llmio custom provider) ─────────────────────────────────
# Copy this to .env and fill in your values
LLMIO_BASE_URL=https://your-llmio-gateway.example.com/openai/v1
LLMIO_API_KEY=your-api-key-here
PI_PROVIDER=llmio
PI_MODEL=deepseek-v4-flash

# ── Sandbox Service ──────────────────────────────────────────────────
SANDBOX_LOG_LEVEL=INFO
SANDBOX_SESSION_TTL_MINUTES=30

# ── Agent WebUI (host ports, change if conflicting) ──────────────────
AGENT_PORT=3000
SANDBOX_PORT=8083
SANDBOX_MCP_PORT=8093
