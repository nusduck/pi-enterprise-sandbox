{
  "name": "pi-enterprise-agent",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.19.0 <23"
  },
  "scripts": {
    "start": "node server.js",
    "start:http": "node server.js",
    "start:worker": "node worker.js",
    "dev": "node --watch server.js",
    "dev:worker": "node --watch worker.js",
    "test": "node --test tests/*.test.js tests/sdk-compat/*.test.js",
    "test:mysql:unit": "node --test tests/mysql/*.unit.test.js",
    "test:mysql:integration": "node --test tests/mysql/*.integration.test.js",
    "test:mysql": "node --test tests/mysql/**/*.test.js tests/mysql/*.test.js",
    "test:redis:unit": "node --test tests/redis/*.unit.test.js",
    "test:redis:integration": "node --test tests/redis/*.integration.test.js",
    "test:redis": "node --test tests/redis/**/*.test.js tests/redis/*.test.js",
    "test:run-services": "node --test tests/run-services/**/*.test.js",
    "test:t4": "node --test tests/http/**/*.test.js tests/bootstrap/**/*.test.js",
    "test:a2a": "node --test tests/a2a/**/*.test.js tests/a2a/*.test.js",
    "test:pr14": "node --test tests/pr14/**/*.test.js tests/pr14/*.test.js",
    "migrate:latest": "node src/infrastructure/mysql/cli-migrate.js latest",
    "migrate:rollback": "node src/infrastructure/mysql/cli-migrate.js rollback",
    "migrate:rollback-all": "node src/infrastructure/mysql/cli-migrate.js rollback-all",
    "migrate:status": "node src/infrastructure/mysql/cli-migrate.js status",
    "smoke": "node --test tests/listen-smoke.test.js tests/fake-openai-provider.test.js"
  },
  "dependencies": {
    "@company/pi-enterprise-agent-kit": "file:packages/enterprise-agent-kit",
    "@earendil-works/pi-ai": "0.80.3",
    "@earendil-works/pi-coding-agent": "0.80.3",
    "bullmq": "^5.80.2",
    "ioredis": "^5.10.1",
    "knex": "^3.1.0",
    "mysql2": "^3.14.0",
    "typebox": "1.3.6"
  }
}
